default_platform(:ios)

WORKSPACE        = "ios/cocarrApp.xcworkspace"
SCHEME           = "cocarrApp"
APP_IDENTIFIER   = "com.iappwiz.cocarr"
FIREBASE_APP_ID  = "1:32758101659:ios:acba96f25b127d4a28783e" # from ios/cocarrApp/GoogleService-Info.plist

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Fetch signing certs/profiles from the match repo (read-only, CI-safe)"
  lane :sync_signing do
    match(
      type: "adhoc",
      app_identifier: APP_IDENTIFIER,
      readonly: true
    )
  end

  desc "Build the app and push it to Firebase App Distribution"
  lane :distribute do
    sync_signing

    increment_build_number(
      xcodeproj: "ios/cocarrApp.xcodeproj",
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s
    )

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      export_method: "ad-hoc",
      output_directory: "build",
      output_name: "cocarrApp.ipa",
      export_options: {
        provisioningProfiles: {
          APP_IDENTIFIER => "match AdHoc #{APP_IDENTIFIER}"
        }
      }
    )

    firebase_app_distribution(
      app: FIREBASE_APP_ID,
      service_credentials_file: ENV["FIREBASE_SERVICE_ACCOUNT_FILE"] || "firebase-service-account.json",
      groups: ENV["FIREBASE_TESTER_GROUPS"] || "internal-testers",
      release_notes: ENV["RELEASE_NOTES"] || "CI build #{ENV['GITHUB_SHA']&.slice(0, 7)} — #{Time.now.strftime('%Y-%m-%d %H:%M')}",
      ipa_path: "build/cocarrApp.ipa"
    )
  end

  error do |lane, exception|
    UI.error("Lane #{lane} failed: #{exception.message}")
  end
end
